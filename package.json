{
  "name": "auto-skeleton-react-and-native",
  "version": "1.0.2",
  "description": "Automatically generate and render skeleton loading screens based on your React and React Native components. No configuration needed.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./dist/index.js",
      "require": "./dist/index.js",
      "import": "./dist/index.esm.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./native": {
      "react-native": "./dist/native/index.js",
      "require": "./dist/native/index.js",
      "import": "./dist/native/index.esm.js",
      "types": "./dist/native/index.d.ts",
      "default": "./dist/native/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "native.js",
    "native.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:watch": "rollup -c rollup.config.js --watch",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run build",
    "example": "cd example && npm start",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "skeleton",
    "loading",
    "auto-skeleton",
    "skeleton-loader",
    "react",
    "react-native",
    "placeholder",
    "shimmer",
    "skeleton-screen",
    "loading-screen",
    "ui",
    "component"
  ],
  "author": {
    "name": "Auto Skeleton Contributors",
    "url": "https://github.com/auto-skeleton/auto-skeleton"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/auto-skeleton/auto-skeleton.git"
  },
  "bugs": {
    "url": "https://github.com/auto-skeleton/auto-skeleton/issues"
  },
  "homepage": "https://auto-skeleton.anshulladdha.in/",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-native": "^0.85.2",
    "rollup": "^4.9.6",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "ts-jest": "^29.4.9",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "tslib": "^2.6.2"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
