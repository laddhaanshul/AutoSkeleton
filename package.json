{
  "name": "auto-skeleton",
  "version": "1.0.0",
  "description": "Automatically generate and render skeleton loading screens based on your React and React Native components. No configuration needed.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./dist/index.js",
      "require": "./dist/index.js",
      "import": "./dist/index.esm.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./native": {
      "react-native": "./dist/native/index.js",
      "require": "./dist/native/index.js",
      "import": "./dist/native/index.esm.js",
      "types": "./dist/native/index.d.ts",
      "default": "./dist/native/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "native.js",
    "native.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:watch": "rollup -c rollup.config.js --watch",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run build",
    "example": "cd example && npm start",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "skeleton",
    "loading",
    "auto-skeleton",
    "skeleton-loader",
    "react",
    "react-native",
    "placeholder",
    "shimmer",
    "skeleton-screen",
    "loading-screen",
    "ui",
    "component"
  ],
  "author": {
    "name": "Auto Skeleton Contributors",
    "url": "https://github.com/auto-skeleton/auto-skeleton"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/auto-skeleton/auto-skeleton.git"
  },
  "bugs": {
    "url": "https://github.com/auto-skeleton/auto-skeleton/issues"
  },
  "homepage": "https://auto-skeleton.dev",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "rollup": "^4.9.6",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "tslib": "^2.6.2"
  }
}
